---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SkipLink from '../components/SkipLink.astro';
import { ACCENTS, DEFAULT_ACCENT } from '../lib/accents';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string | undefined;
  ogImage?: string | undefined; // absolute URL to OG image
  noindex?: boolean | undefined;
  /** JSON-LD structured data, rendered in <head> */
  schema?: Record<string, unknown> | undefined;
}

const { title, description = '', ogImage, noindex = false, schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogUrl = ogImage ?? new URL('/og/default.png', Astro.site).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex" />}

  <!-- OG / Twitter -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogUrl} />

  <link rel="alternate" type="application/rss+xml" title="Caio | Frontend Blog" href={new URL('/rss.xml', Astro.site)} />

  <!-- Fonts: self-hosted subsetted woff2, declared in global.css -->
  <link rel="preload" href="/fonts/zen-old-mincho-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/zen-kaku-gothic-new-400.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Theme + accent: applied before first paint to prevent flash. -->
  <script is:inline define:vars={{ accents: ACCENTS, defaultAccent: DEFAULT_ACCENT }}>
    (function () {
      const root = document.documentElement;

      function read(key) {
        try {
          return localStorage.getItem(key);
        } catch {
          return null;
        }
      }
      function write(key, value) {
        try {
          localStorage.setItem(key, value);
        } catch {}
      }

      const currentTheme = () =>
        root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      const getAccentId = () => read('accent') || defaultAccent;

      function applyAccent(id) {
        const a = accents[id] || accents[defaultAccent];
        const dark = currentTheme() === 'dark';
        const L = dark ? a.dl : a.l;
        const strong = (L + (dark ? 0.07 : -0.06)).toFixed(3);
        root.style.setProperty('--shu', `oklch(${L} ${a.c} ${a.h})`);
        root.style.setProperty('--shu-strong', `oklch(${strong} ${a.c} ${a.h})`);
        if (dark) {
          root.style.setProperty('--paper', `oklch(0.235 0.008 ${a.ph})`);
          root.style.setProperty('--surface', `oklch(0.275 0.008 ${a.ph})`);
          root.style.setProperty('--surface-sunk', `oklch(0.205 0.007 ${a.ph})`);
          root.style.setProperty('--line', `oklch(0.36 0.010 ${a.ph})`);
        } else {
          // Light mode keeps the default washi neutrals from global.css.
          root.style.removeProperty('--paper');
          root.style.removeProperty('--surface');
          root.style.removeProperty('--surface-sunk');
          root.style.removeProperty('--line');
        }
      }

      function setTheme(theme) {
        root.setAttribute('data-theme', theme);
        write('theme', theme);
        applyAccent(getAccentId());
        document.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
      }

      function setAccent(id) {
        write('accent', id);
        applyAccent(id);
        document.dispatchEvent(new CustomEvent('accentchange', { detail: { accent: id } }));
      }

      // First paint: honour stored/system theme, then apply the stored accent.
      const theme =
        read('theme') ||
        (window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light');
      root.setAttribute('data-theme', theme);
      applyAccent(getAccentId());

      window.__ui = { setTheme, setAccent, getAccentId, currentTheme };
    })();
  </script>
</head>
<body>
  <SkipLink />
  <Header />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
