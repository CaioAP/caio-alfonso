---
// No props: BaseLayout's inline script sets data-theme before first paint; this only toggles.
---
<button
  id="theme-toggle"
  class="toggle"
  aria-pressed="false"
  style="cursor:pointer;background:transparent;border:1px solid var(--line);color:var(--ink-muted);border-radius:var(--radius-1);padding:.4rem .7rem;font-family:var(--font-mono);font-size:.72rem;min-height:44px;"
>light / dark</button>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle') as HTMLButtonElement;

  const sync = () =>
    btn.setAttribute('aria-pressed', String(root.getAttribute('data-theme') === 'dark'));

  // First paint + accent already handled by BaseLayout's inline controller.
  sync();

  btn.addEventListener('click', () =>
    window.__ui.setTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'),
  );

  document.addEventListener('themechange', sync);
</script>
