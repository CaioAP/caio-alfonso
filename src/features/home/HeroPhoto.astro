---
import { urlFor } from '../../content/imageUrl';
import { sanityConfigured } from '../../content/client';

interface Props {
  photo?: { asset: object; alt: string };
}
const { photo } = Astro.props;
// When Sanity is not configured (fixture builds), use the local profile photo
// instead of the generic placeholder builder.
const src = sanityConfigured && photo
  ? urlFor(photo.asset).width(640).height(640).fit('crop').url()
  : '/images/caio-profile.png';
const alt = photo?.alt ?? 'Caio Alfonso';
---
<div class="hero-photo fade-up delay-2">
  <img src={src} alt={alt} width="400" height="500" loading="eager" />
</div>

<style>
  .hero-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--line);
    background: var(--surface-sunk);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 760px) {
    .hero-photo {
      order: -1;
      max-width: 200px;
    }
  }
</style>
